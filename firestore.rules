rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------
    // Helper Functions
    // ------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole(userId) {
      // Fetches the user's role from their document in the 'users' collection.
      // This is called by other helper functions.
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isOwner(userId) {
      // Checks if the requesting user is the owner of the document.
      return isSignedIn() && request.auth.uid == userId;
    }

    function requestUserRole() {
      // Gets the role of the user making the request.
      return getUserRole(request.auth.uid);
    }
    
    function isSuperAdmin() {
      // Checks if the user is a Super Admin.
      return isSignedIn() && requestUserRole() == 'super_admin';
    }

    function isAdmin() {
      // Checks if the user is a Super Admin or Head Coordinator.
      if (!isSignedIn()) { return false; }
      let role = requestUserRole();
      return role == 'super_admin' || role == 'head_coordinator';
    }

    function isCoordinator() {
      // Checks if the user is an Event Coordinator, Head Coordinator, or Super Admin.
      if (!isSignedIn()) { return false; }
      let role = requestUserRole();
      return role == 'event_coordinator' || isAdmin();
    }
    
    function isStudent() {
      // Checks if the user is a Student.
      return isSignedIn() && requestUserRole() == 'student';
    }

    // ------------------
    // Collection Rules
    // ------------------

    match /users/{userId} {
      // Public read for evaluators (client must filter to show only public fields).
      // Owner can read their own document.
      // Coordinators and admins can read any user document.
      allow read: if (get(/databases/$(database)/documents/users/$(userId)).data.role == 'evaluator') || isOwner(userId) || isCoordinator();
      
      // Owner can write to their own document.
      // Admins can write to any user document.
      // All writes must be from an authenticated user.
      allow write: if isOwner(userId) || isAdmin();
    }

    match /institutions/{instId} {
      // Publicly readable.
      allow read: if true;
      // Only admins can write. All writes must be from an authenticated user.
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      // Published events are publicly readable.
      // Coordinators and admins can read any event, regardless of status.
      allow read: if resource.data.status == 'published' || isCoordinator();
      
      // Only coordinators and admins can write to events.
      // All writes must be from an authenticated user.
      allow write: if isCoordinator();
    }

    match /registrations/{regId} {
      // A student can read their own registrations.
      // Coordinators can read all registrations for any event.
      allow read: if isOwner(resource.data.userId) || isCoordinator();

      // Only the user who owns the registration can create or modify it.
      allow write: if isOwner(resource.data.userId);
    }

    match /evaluations/{evalId} {
      // An evaluator can read their own evaluation.
      // A coordinator can read all evaluations for an event.
      allow read: if isOwner(resource.data.evaluatorId) || isCoordinator();

      // Only the assigned evaluator can write the evaluation.
      allow write: if isOwner(resource.data.evaluatorId);
    }

    match /jobs/{jobId} {
      // Active jobs are publicly readable.
      // Super admins can read jobs of any status.
      allow read: if resource.data.status == 'active' || isSuperAdmin();
      
      // Only super admins can write to jobs.
      allow write: if isSuperAdmin();
    }

    match /jobApplications/{appId} {
      // A student can read their own job applications.
      // A super admin can read all job applications.
      allow read: if isOwner(resource.data.userId) || isSuperAdmin();

      // Only the user who owns the application can write to it.
      allow write: if isOwner(resource.data.userId);
    }

    match /notifications/{notificationId} {
      // A user can read or delete their own notifications.
      allow read, delete: if isOwner(resource.data.userId);
      
      // Notifications are only created by the backend (Cloud Functions).
      allow write: if false;
    }

    match /announcements/{announcementId} {
      // All announcements are publicly readable.
      allow read: if true;

      // Only coordinators and admins can create or modify announcements.
      allow write: if isCoordinator();
    }

    match /audit_logs/{logId} {
      // Only super admins can read audit logs.
      allow read: if isSuperAdmin();

      // Audit logs are only created by the backend (Cloud Functions).
      allow write: if false;
    }

    match /feedback/{feedbackId} {
      // Coordinators can read feedback for their events.
      allow read: if isCoordinator();
      
      // Students can write their own feedback for an event.
      allow write: if isOwner(resource.data.userId);
    }

    match /messages/{messageId} {
      // Checks if the requesting user is a participant (volunteer or coordinator) in the event.
      function isEventParticipant() {
        let eventDoc = get(/databases/$(database)/documents/events/$(resource.data.eventId)).data;
        return request.auth.uid == eventDoc.hostCoordinatorId 
               || request.auth.uid in eventDoc.assignedCoordinatorIds 
               || request.auth.uid in eventDoc.assignedVolunteerIds;
      }
      
      // Only event participants can read or write messages.
      allow read, write: if isSignedIn() && (isEventParticipant() || isAdmin());
    }

    match /volunteerZones/{zoneId} {
      // A volunteer can read their own zone assignment.
      // A coordinator can read all zone assignments for an event.
      allow read: if isOwner(resource.data.volunteerId) || isCoordinator();

      // Only coordinators can create or modify zone assignments.
      allow write: if isCoordinator();
    }
  }
}
