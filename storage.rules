rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to get user role
    function getUserRole(userId) {
      return firestore.get(/databases/(default)/documents/users/$(userId)).data.role;
    }

    match /resumes/students/{userId}/{fileName} {
      // Owner, admin, and evaluator roles can read resumes.
      // Max size: 5MB, PDF only.
      allow read: if request.auth.uid == userId 
                    || getUserRole(request.auth.uid) == 'super_admin' 
                    || getUserRole(request.auth.uid) == 'evaluator';
      allow write: if request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('application/pdf');
    }

    match /profiles/{userId}.jpg {
      // Profile pictures are public.
      // Max size: 2MB, image only.
      allow read: if true;
      allow write: if request.auth.uid == userId && request.resource.size < 2 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /certificates/{registrationId}.pdf {
      // Certificates are public.
      // Only authenticated users (Cloud Functions) can write certificates.
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{eventId}/cover {
      // Event cover images are public.
      // Only the event coordinator or an admin can write event cover images.
      function isEventCoordinator() {
        let eventDoc = firestore.get(/databases/(default)/documents/events/$(eventId)).data;
        return request.auth.uid == eventDoc.hostCoordinatorId;
      }
      allow read: if true;
      allow write: if (isEventCoordinator() || getUserRole(request.auth.uid) == 'super_admin');
    }

    match /institutions/{institutionId}/logo {
      // Institution logos are public.
      // Only admins can write institution logos.
      allow read: if true;
      allow write: if getUserRole(request.auth.uid) == 'super_admin';
    }

    match /submissions/{eventId}/{stageNumber}/{registrationId}/{fileName} {
      // Owner, assigned evaluators, and coordinators can read submissions.
      // Owner can write before stage deadline.
      function isAssignedEvaluator(eventId) {
        let eventDoc = firestore.get(/databases/(default)/documents/events/$(eventId)).data;
        return request.auth.uid in eventDoc.assignedEvaluatorIds;
      }
      
      function isSubmissionOwner(registrationId) {
        let regDoc = firestore.get(/databases/(default)/documents/registrations/$(registrationId)).data;
        return request.auth.uid == regDoc.userId;
      }

      function isBeforeDeadline(eventId, stageNumber) {
          let stage = firestore.get(/databases/(default)/documents/events/$(eventId)).data.stages[stageNumber - 1];
          return request.time < stage.deadline;
      }

      allow read: if isSubmissionOwner(registrationId) 
                    || isAssignedEvaluator(eventId) 
                    || getUserRole(request.auth.uid) == 'event_coordinator';
      allow write: if isSubmissionOwner(registrationId) && isBeforeDeadline(eventId, stageNumber);
    }
  }
}
